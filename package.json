{
  "name": "web-template-ts",
  "description": "A TypeScript starter for static sites.",
  "version": "1.0.0",
  "private": true,
  "author": "Scribbler Studio",
  "license": "MIT",
  "keywords": [
    "gatsby",
    "starter",
    "typescript"
  ],
  "scripts": {
    "start": "gatsby develop",
    "build": "yarn type-check && yarn lint && yarn format && yarn test && gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "yarn jest",
    "type-check": "tsc --noEmit",
    "lint": "eslint --ignore-path .gitignore \"src/**/*.+(ts|js|tsx)\"",
    "format": "prettier --ignore-path .gitignore \"src/**/*.+(ts|js|tsx)\" --write"
  },
