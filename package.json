    "@react-three/flex": "^1.0.1",
    "@use-gesture/react": "^10.3.0",
    "contentful-resolve-response": "^1.9.3",
    "dotenv": "^16.0.3",
    "framer-motion": "^10.16.5",
    "framer-motion-3d": "^10.18.0",
    "gatsby": "^5.0.1",
    "gatsby-plugin-image": "^3.12.3",
